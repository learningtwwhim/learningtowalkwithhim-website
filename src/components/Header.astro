---
import { SITE_TITLE, NAV_LINKS } from '../consts.js';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 bg-cream/95 backdrop-blur border-b border-navy/10">
  <nav class="mx-auto max-w-6xl flex items-center justify-between px-4 py-4 md:py-5">
    <a href="/" class="font-heading text-xl md:text-2xl font-semibold text-navy no-underline">
      {SITE_TITLE}
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="md:hidden text-navy"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>

    <ul
      id="nav-menu"
      class="hidden md:flex absolute md:static top-full left-0 right-0 md:top-auto bg-cream md:bg-transparent border-b md:border-0 border-navy/10 flex-col md:flex-row md:items-center gap-1 md:gap-6 px-4 md:px-0 py-3 md:py-0 list-none m-0"
    >
      {NAV_LINKS.map(({ href, label }) => {
        const normalized = href.replace(/\/$/, '') || '/';
        const isActive = normalized === pathname || (normalized !== '/' && pathname.startsWith(normalized));
        return (
          <li>
            <a
              href={href}
              class={`block py-2 md:py-1 no-underline font-medium text-navy hover:text-gold transition-colors ${isActive ? 'border-b-2 border-gold' : ''}`}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
