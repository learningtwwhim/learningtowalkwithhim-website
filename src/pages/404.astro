---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for can't be found."
>
  <section class="bg-cream">
    <div class="mx-auto max-w-2xl px-4 py-24 md:py-32 text-center">
      <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-3">404</p>
      <h1 class="font-heading text-5xl md:text-6xl text-navy mb-4">
        We can't find that page
      </h1>
      <p class="text-lg text-ink/80 mb-10">
        The link may be broken, or the page may have moved. Let's get you back on the path.
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="/"
          class="rounded-md bg-navy text-cream px-5 py-2.5 font-medium hover:bg-gold hover:text-navy no-underline transition-colors"
        >
          Go home
        </a>
        <a
          href="/blog"
          class="rounded-md border border-navy text-navy px-5 py-2.5 font-medium hover:bg-navy hover:text-cream no-underline transition-colors"
        >
          Read the blog
        </a>
        <a
          href="/contact"
          class="rounded-md border border-navy text-navy px-5 py-2.5 font-medium hover:bg-navy hover:text-cream no-underline transition-colors"
        >
          Contact me
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
