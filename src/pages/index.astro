---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BOOK_TITLE, BOOK_SUBTITLE, AUTHOR, AMAZON_URL } from '../consts.js';

// Rotating quotes from the book. Picks change every 2 days.
// Each rotation always includes one Savior-pointing quote plus two general lessons.
const SAVIOR_QUOTES = [
  "He is a Savior close enough to catch you when you begin to sink.",
  "If He could trust the Father's plan even when it led to the cross, you can trust it too.",
  "When you make the Savior the center of your mission, your mission becomes what it was meant to be.",
  "Keep walking with Him.",
  "The Savior gave everything. He held nothing back.",
  "He doesn't abandon you when you struggle. He reaches out, lifts you up, and walks beside you until you're safe.",
  "He is your anchor, your example, your source of strength.",
  "Your mission isn't about you. It's about Him.",
];

const OTHER_QUOTES = [
  "God doesn't waste anyone's willingness to try.",
  "If God can work with someone like me, He can work with anyone.",
  "The Lord measures your offering, not your timeline.",
  "He doesn't waste your service.",
  "Treat everyone like they matter. Because they do.",
  "Your job is to plant, not to control the growth.",
  "Goals are meant to motivate you, not define you.",
  "Pride dressed up as patience is still pride.",
  "The Lord is not making mistakes with your assignments.",
  'Instead of asking, "Why am I here?" try, "What is here for me?"',
  "When you obsess over numbers, you stop seeing people.",
  "You don't convert people. The Spirit does.",
  "Your job isn't to have all the answers. It's to be a conduit for the Spirit.",
  "Awareness is the first step toward change.",
  "Obedience, even reluctant obedience, is always worth it.",
];

function pickQuotes(dayIndex) {
  const period = Math.floor(dayIndex / 2);
  const savior = SAVIOR_QUOTES[period % SAVIOR_QUOTES.length];
  const otherStart = (period * 2) % OTHER_QUOTES.length;
  const otherA = OTHER_QUOTES[otherStart];
  const otherB = OTHER_QUOTES[(otherStart + 1) % OTHER_QUOTES.length];
  // Savior quote sits in the middle slot for visual emphasis.
  return [otherA, savior, otherB];
}

const _now = new Date();
const _start = new Date(_now.getFullYear(), 0, 0);
const _dayOfYear = Math.floor((_now - _start) / 86400000);
const initialQuotes = pickQuotes(_dayOfYear);
---

<BaseLayout
  title={null}
  description={`${BOOK_TITLE}: ${BOOK_SUBTITLE}. By ${AUTHOR}.`}
>
  <!-- HERO -->
  <section class="bg-cream">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-24 grid md:grid-cols-2 gap-10 md:gap-16 items-start">
      <!-- Book cover -->
      <div class="order-2 md:order-1">
        <img
          src="/book-cover.jpg"
          alt={`Cover of ${BOOK_TITLE} by ${AUTHOR}`}
          width="800"
          height="1200"
          class="aspect-[2/3] w-full max-w-sm mx-auto rounded-md shadow-2xl object-cover"
        />
        <p class="mt-4 max-w-sm mx-auto text-center text-sm text-ink/80">
          Don't you just love this book cover? It was created by the incredibly talented
          <strong class="text-navy">McKay Fife</strong>. The rest of his work is just as good.
          <a
            href="https://www.instagram.com/mckayfife_illustration/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-navy underline hover:text-gold font-medium"
          >Go see for yourself</a>.
        </p>
      </div>

      <!-- Headline + email form -->
      <div class="order-1 md:order-2">
        <p class="text-gold uppercase tracking-widest text-sm font-semibold mb-4">A new book by {AUTHOR}</p>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl leading-tight text-navy mb-4">
          From Reluctant Missionary to Devoted Disciple
        </h1>
        <p class="text-lg md:text-xl text-ink/80 mb-8">
          Lessons of faith, focus, and the Savior's love, drawn from one missionary's journey,
          and an invitation to walk with Him in your own.
        </p>

        <!-- Launch banner -->
        <a
          href={AMAZON_URL}
          target="_blank"
          rel="noopener"
          class="launch-banner launch-pulse block rounded-lg px-5 py-5 mb-6 no-underline text-center shadow-lg ring-2 ring-navy/20"
        >
          <p class="font-heading font-bold text-3xl md:text-4xl text-navy m-0 leading-tight tracking-wide">
            Releasing Monday
          </p>
          <p class="text-base md:text-lg text-navy mt-2 m-0 font-semibold">
            Pre-order the eBook on Amazon now. Paperback and eBook both release Monday, May 18.
          </p>
        </a>

        <!-- Free guide intro -->
        <h2 class="font-heading text-2xl md:text-3xl text-navy mb-3 leading-tight">
          Built for the Journey
        </h2>
        <p class="text-base md:text-lg text-ink/80 mb-3">
          This is more than a newsletter. When you join, you get the Five Lessons Guide
          today and everything I create going forward. Practical resources built for:
        </p>
        <ul class="list-disc pl-6 text-base md:text-lg text-ink/80 mb-3 space-y-1">
          <li>Those still deciding if they want to serve</li>
          <li>Those currently serving</li>
          <li>Those just returned home</li>
          <li>The parents that pray for them</li>
          <li>Leaders walking alongside them</li>
          <li>Anyone still learning to walk with Him</li>
        </ul>
        <p class="text-base md:text-lg text-ink/80 mb-5">Free. Always yours.</p>

        <!-- Custom Kit subscribe form (posts directly to Kit, bypasses recommendations modal) -->
        <form
          id="kit-subscribe-form"
          action="https://app.kit.com/forms/9413345/subscriptions"
          method="post"
          class="space-y-3"
          novalidate
        >
          <label class="block">
            <span class="sr-only">First name</span>
            <input
              type="text"
              name="fields[first_name]"
              placeholder="First name"
              required
              class="w-full rounded-md border border-ink/20 bg-white px-4 py-3 text-base text-ink placeholder-ink/50 focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/40"
            />
          </label>
          <label class="block">
            <span class="sr-only">Email address</span>
            <input
              type="email"
              name="email_address"
              placeholder="Email address"
              required
              autocomplete="email"
              class="w-full rounded-md border border-ink/20 bg-white px-4 py-3 text-base text-ink placeholder-ink/50 focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/40"
            />
          </label>
          <!-- honeypot -->
          <input
            type="text"
            name="hp_field"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
            style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0"
          />
          <button
            type="submit"
            class="w-full rounded-md bg-gold px-6 py-3 text-base font-semibold text-white hover:bg-gold/90 transition-colors disabled:opacity-60 disabled:cursor-not-allowed"
          >
            I'm In
          </button>
          <p
            id="kit-subscribe-error"
            class="hidden mt-2 text-sm text-red-700"
            role="alert"
          ></p>
        </form>

        <div
          id="kit-subscribe-success"
          class="hidden rounded-md border border-green/30 bg-green/10 p-5 text-center"
          role="status"
        >
          <p class="font-heading text-2xl text-navy mb-1">Thank you!</p>
          <p class="text-base text-ink/85">
            Check your email for the Five Lessons Guide. If you don't see it, take a
            peek in the promotions or spam folder.
          </p>
        </div>

        <p class="mt-3 text-base md:text-lg text-center" style="color: #2c2c2c;">
          I'll also send you occasional letters. Unsubscribe anytime.
        </p>

        <script is:inline>
          (function () {
            var form = document.getElementById('kit-subscribe-form');
            var success = document.getElementById('kit-subscribe-success');
            var errorEl = document.getElementById('kit-subscribe-error');
            if (!form) return;

            form.addEventListener('submit', function (e) {
              e.preventDefault();
              errorEl.classList.add('hidden');
              errorEl.textContent = '';

              // honeypot: silently drop bot submissions
              if (form.hp_field && form.hp_field.value) {
                form.reset();
                form.classList.add('hidden');
                success.classList.remove('hidden');
                return;
              }

              var btn = form.querySelector('button[type="submit"]');
              var originalLabel = btn.textContent;
              btn.disabled = true;
              btn.textContent = 'Sending...';

              var data = new FormData(form);
              fetch(form.action, {
                method: 'POST',
                body: data,
                headers: { Accept: 'application/json' },
              })
                .then(function (res) {
                  if (!res.ok) throw new Error('Subscription failed');
                  return res.json().catch(function () { return {}; });
                })
                .then(function () {
                  form.reset();
                  form.classList.add('hidden');
                  success.classList.remove('hidden');
                  // scroll the success block into view
                  if (success.scrollIntoView) {
                    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
                  }
                })
                .catch(function () {
                  errorEl.textContent =
                    "Something went wrong. Please try again, or email ken@learningtowalkwithhim.com.";
                  errorEl.classList.remove('hidden');
                  btn.disabled = false;
                  btn.textContent = originalLabel;
                });
            });
          })();
        </script>
      </div>
    </div>
  </section>

  <!-- FROM THE BOOK -->
  <section class="bg-navy text-cream">
    <div id="rotating-quotes" class="mx-auto max-w-6xl px-4 py-12 grid gap-8 md:grid-cols-3">
      {initialQuotes.map((q) => (
        <figure class="text-center md:text-left">
          <blockquote class="font-heading text-xl italic leading-snug">
            "{q}"
          </blockquote>
          <figcaption class="mt-2 text-sm text-cream/70"><em>Learning to Walk with Him</em></figcaption>
        </figure>
      ))}
    </div>
  </section>

  <script is:inline define:vars={{ SAVIOR_QUOTES, OTHER_QUOTES }}>
    (function () {
      var now = new Date();
      var start = new Date(now.getFullYear(), 0, 0);
      var day = Math.floor((now - start) / 86400000);
      var period = Math.floor(day / 2);
      var savior = SAVIOR_QUOTES[period % SAVIOR_QUOTES.length];
      var otherStart = (period * 2) % OTHER_QUOTES.length;
      var otherA = OTHER_QUOTES[otherStart];
      var otherB = OTHER_QUOTES[(otherStart + 1) % OTHER_QUOTES.length];
      var picks = [otherA, savior, otherB];
      var blocks = document.querySelectorAll('#rotating-quotes blockquote');
      blocks.forEach(function (el, i) {
        if (picks[i]) el.textContent = '"' + picks[i] + '"';
      });
    })();
  </script>

  <!-- WHAT THE BOOK IS -->
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-4 py-16 md:py-20">
      <h2 class="font-heading text-3xl md:text-4xl text-navy mb-6">What the book is</h2>
      <p class="text-lg text-ink/85 mb-4">
        <em>Learning to Walk with Him</em> is part memoir, part field guide for discipleship.
        It tells the story of a reluctant young missionary who discovered, slowly and through
        many missteps, that following the Savior is not about perfect performance. It is
        about a deepening walk.
      </p>
      <p class="text-lg text-ink/85">
        Through five lessons drawn from the mission field, Ken offers practical,
        scripturally-rooted invitations to walk a little closer to Christ each day.
      </p>
      <ul class="mt-6 space-y-2 text-lg text-ink/85 list-none p-0">
        <li><strong class="text-navy">Lesson 1.</strong> You never know who you will touch.</li>
        <li><strong class="text-navy">Lesson 2.</strong> You are sent where you are sent for a reason.</li>
        <li><strong class="text-navy">Lesson 3.</strong> Keep the Savior's life and ministry as the focus in all you do.</li>
        <li><strong class="text-navy">Lesson 4.</strong> Don't underestimate the power of prayer and the Lord's love for you.</li>
        <li><strong class="text-navy">Lesson 5.</strong> Baptisms aren't the focus; the Savior's love is.</li>
      </ul>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="bg-white border-y border-navy/10">
    <div class="mx-auto max-w-4xl px-4 py-16 md:py-20">
      <h2 class="font-heading text-3xl md:text-4xl text-navy mb-8">Who it's for</h2>
      <ul class="grid md:grid-cols-2 gap-6 list-none p-0">
        <li class="border-l-4 border-gold pl-4">
          <p class="font-heading text-xl text-navy mb-1">Returned and current missionaries</p>
          <p class="text-ink/80">Anyone who has ever felt unworthy of the calling, and is ready to keep walking anyway.</p>
        </li>
        <li class="border-l-4 border-gold pl-4">
          <p class="font-heading text-xl text-navy mb-1">Parents and youth leaders</p>
          <p class="text-ink/80">Looking for honest stories that frame faith as a relationship, not a performance.</p>
        </li>
        <li class="border-l-4 border-gold pl-4">
          <p class="font-heading text-xl text-navy mb-1">Disciples in any season</p>
          <p class="text-ink/80">Whether you're stepping back, starting over, or steady, these lessons meet you where you are.</p>
        </li>
        <li class="border-l-4 border-gold pl-4">
          <p class="font-heading text-xl text-navy mb-1">Skeptics willing to read with an open heart</p>
          <p class="text-ink/80">No shame, no pressure. Just an invitation to walk and see.</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- AUTHOR BIO -->
  <section class="bg-cream">
    <div class="mx-auto max-w-4xl px-4 py-16 md:py-20 grid md:grid-cols-[1fr_2fr] gap-10 items-start">
      <div>
        <img
          src="/Ken_Smith_20260508.png"
          alt={`Photo of ${AUTHOR}`}
          width="400"
          height="400"
          class="aspect-square w-48 rounded-full object-cover border-4 border-green/30 mx-auto md:mx-0"
        />
      </div>
      <div>
        <h2 class="font-heading text-3xl md:text-4xl text-navy mb-4">About {AUTHOR}</h2>
        <p class="text-lg text-ink/85 mb-4">
          Ken Smith didn't leave on his mission with a burning testimony. He went because he
          didn't want to break his mother's heart, and because all his friends were going.
          From 1991 to 1993 he served in the Japan Fukuoka Mission, where the love of
          President and Sister Figuerres and the patient teaching of the Savior began to
          reshape a reluctant young missionary into a disciple.
        </p>
        <p class="text-lg text-ink/85 mb-6">
          In the years since, Ken has invested deeply in the faith of young people, serving
          as a bishop, as a counselor in his stake presidency, and now on a Young Single
          Adult stake high council alongside his wife. He and his wife live in the Pacific
          Northwest, where Ken also holds a senior leadership role in technology. Above all
          else, he is a husband, father, and grandfather. <em>Learning to Walk with Him</em>
          is his first book.
        </p>
        <a
          href="/about"
          class="inline-block rounded-md border border-navy text-navy px-5 py-2 font-medium hover:bg-navy hover:text-cream no-underline"
        >
          Read more about Ken
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .launch-banner {
    background: linear-gradient(135deg, #d99c3a 0%, #c9892a 50%, #b07820 100%);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .launch-banner:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(27, 58, 92, 0.25);
  }
  .launch-pulse {
    animation: launch-pulse 1.8s ease-in-out infinite;
  }
  @keyframes launch-pulse {
    0% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(201, 137, 42, 0.7), 0 4px 12px rgba(27, 58, 92, 0.15);
    }
    50% {
      transform: scale(1.03);
      box-shadow: 0 0 0 14px rgba(201, 137, 42, 0), 0 8px 20px rgba(27, 58, 92, 0.25);
    }
    100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(201, 137, 42, 0), 0 4px 12px rgba(27, 58, 92, 0.15);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .launch-pulse { animation: none; }
  }
</style>
